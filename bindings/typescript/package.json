{
  "name": "@kainetic/runtime",
  "version": "0.1.0",
  "description": "Production-grade Rust runtime for agentic AI — Node.js bindings",
  "license": "Apache-2.0",
  "main": "index.js",
  "types": "index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/kainetic/kainetic"
  },
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.ts"]
  },
  "devDependencies": {
    "@napi-rs/cli": "^2.18.0",
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">= 16"
  },
  "napi": {
    "name": "kainetic",
    "triples": {
      "defaults": true
    }
  }
}
